# ============================================
# 一会去哪儿 · Vercel 部署环境变量
# ============================================
# 在 Vercel 项目设置 → Settings → Environment Variables 中添加

# 硅基流动 API Key（必填，用于免费AI推荐）
# 注册地址：https://cloud.siliconflow.cn/i/9gQFmemf
# 注册后进入 https://cloud.siliconflow.cn/account/ak 创建 API Key
SILICONFLOW_API_KEY=你的API_KEY

# ============================================
# 以下为可选环境变量（用户自行配置可获得更精准地图数据）
# ============================================

# 高德地图 API Key（可选，用于更精准的地图POI搜索）
# 申请地址：https://console.amap.com/dev/key/app
AMAP_API_KEY=

# 百度地图 API Key（可选，备用地图数据源）
# 申请地址：https://lbsyun.baidu.com/apiconsole/key
BAIDU_API_KEY=
